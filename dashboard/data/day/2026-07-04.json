ks": 1, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Negative", "topics": ["Russia sanctions", "Geopolitics"]}}, {"id": "2073322893728215357", "url": "https://x.com/finsquawk_/status/2073322893728215357", "text": "Ukraine's military targets oil and defense sites near St. Petersburg: Zelenskiy #OOTT", "time": "08:27", "author": "finsquawk_", "author_name": "FinSquawk", "followers": 2496, "views": 919, "likes": 3, "replies": 0, "retweets": 1, "quotes": 0, "bookmarks": 1, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Negative", "topics": ["Russia sanctions", "Geopolitics"]}}, {"id": "2073331082225750167", "url": "https://x.com/JavierBlas/status/2073331082225750167", "text": "@enerstrat @TheEconomist That “oil is dead” cover — I’m fairly sure that’s a fake one.", "time": "09:00", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 5762, "likes": 15, "replies": 4, "retweets": 0, "quotes": 0, "bookmarks": 1, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Neutral", "topics": []}}, {"id": "2073349964399292542", "url": "https://x.com/aeberman12/status/2073349964399292542", "text": "WTI futures price fell $0.45 (1%) from $69.23 to $68.78 week ending July 3\n\nPrice discovery is testing a post-Hormuz full closure floor\n#energy #OOTT #oilandgas #WTI #CrudeOil #fintwit #OPEC #Commodities #commoditiesmarket https://t.co/KSWxmHLXmy", "time": "10:15", "author": "aeberman12", "author_name": "Art Berman", "followers": 53616, "views": 2957, "likes": 26, "replies": 2, "retweets": 2, "quotes": 0, "bookmarks": 2, "labels": {"relevant": true, "price_sentiment": "Bearish", "emotional_sentiment": "Neutral", "topics": ["Prices/technicals"]}}, {"id": "2073387598643450303", "url": "https://x.com/LiveSquawk/status/2073387598643450303", "text": "#OOTT", "time": "12:44", "author": "LiveSquawk", "author_name": "LiveSquawk", "followers": 436343, "views": 22651, "likes": 8, "replies": 1, "retweets": 0, "quotes": 0, "bookmarks": 0, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Neutral", "topics": ["Tankers/shipping", "Iran"]}}, {"id": "2073402755847188694", "url": "https://x.com/TommyDeepwater/status/2073402755847188694", "text": "Offshore drilling giants Brazil and Norway meet in the World Cup on July 5 🇧🇷 🇳🇴\n\nBrazil's youthful pre-salt giants Tupi, Búzios &amp; Mero are producing 2.4 million bpd. Búzios will be adding 750k bpd capacity in '27 👀\n\nNorway is the veteran, holding production &gt;4 million boe #OOTT https://t.co/", "time": "13:45", "author": "TommyDeepwater", "author_name": "Tommy Lee", "followers": 14048, "views": 22132, "likes": 98, "replies": 5, "retweets": 7, "quotes": 1, "bookmarks": 9, "labels": {"relevant": true, "price_sentiment": "Neutral", "emotional_sentiment": "Positive", "topics": ["Supply outlook"]}}, {"id": "2073434003755974953", "url": "https://x.com/NuggetCapital/status/2073434003755974953", "text": "This is one major reason why cracks are high... downstream outages in Russia. Don't get hosed by the permabull manipulation of cold hard facts. #oott", "time": "15:49", "author": "NuggetCapital", "author_name": "Nugget Capital Partners (NCP)", "followers": 7677, "views": 4620, "likes": 17, "replies": 2, "retweets": 0, "quotes": 0, "bookmarks": 2, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Negative", "topics": ["Refining/products", "Russia sanctions"]}}, {"id": "2073440388246081864", "url": "https://x.com/Amalteya3000/status/2073440388246081864", "text": "Guys, do you realize that it is not in China interest to weaken Iran negotiating position through low oil prices and to save US and EU by using its own SPR?\nChinese oil imports will soon pick up again (in fact they already have considering imported Iran OIW).\n#oott #com", "time": "16:14", "author": "Amalteya3000", "author_name": "Amalteya", "followers": 773, "vie