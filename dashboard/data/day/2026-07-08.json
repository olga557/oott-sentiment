s": [{"id": "2074681150220771513", "url": "https://x.com/pickeringenergy/status/2074681150220771513", "text": "This announcement is to notify all parties that my salvos on the overly bearish oil pundits have been completed for tonight. BUT I will not hesitate to bomb them into oblivion if they keep talking about oil gluts and structurally impaired China demand. That is all.  #EFT #OOTT", "time": "02:25", "author": "pickeringenergy", "author_name": "Dan Pickering", "followers": 36384, "views": 13549, "likes": 166, "replies": 17, "retweets": 6, "quotes": 0, "bookmarks": 4, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Positive", "topics": ["Demand outlook", "Supply outlook"]}}, {"id": "2074734014271779038", "url": "https://x.com/JavierBlas/status/2074734014271779038", "text": "A reminder of what the US waiver revocation on Iranian oil sales means -- and doesn't mean: \n\nIran can still sell its oil if it finds a willing buyers (and China has been in the past, and will be again). Yes, Iran will need to discount its oil, but that would be mostly offset by the rise in oil pric", "time": "05:55", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 80633, "likes": 432, "replies": 37, "retweets": 98, "quotes": 11, "bookmarks": 84, "labels": {"relevant": true, "price_sentiment": "Neutral", "emotional_sentiment": "Neutral", "topics": ["Iran", "Geopolitics", "Supply outlook"]}}, {"id": "2074768935904248303", "url": "https://x.com/JavierBlas/status/2074768935904248303", "text": "According to Reuters, China has lifted refined fuel export restrictions for ​the rest of July and allowed a private refiner to resume shipments after a 4-month halt. \nhttps://t.co/xF2hvSAlgw", "time": "08:13", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 61139, "likes": 235, "replies": 9, "retweets": 50, "quotes": 8, "bookmarks": 31, "labels": {"relevant": true, "price_sentiment": "Bearish", "emotional_sentiment": "Neutral", "topics": ["China demand", "Refining/products"]}}, {"id": "2074771468135678039", "url": "https://x.com/JavierBlas/status/2074771468135678039", "text": "US President Donald Trump on Iran:\n\nCeasefire is over \"as far as I’m concerned.\"\n\n\"I don’t want to deal with them anymore,\" he says. However, then he says he would let his negotiators keep talking. But \"I think they’re wasting their time.\"", "time": "08:24", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 107394, "likes": 484, "replies": 32, "retweets": 95, "quotes": 21, "bookmarks": 37, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Negative", "topics": ["Iran", "Geopolitics"]}}, {"id": "2074840269577507228", "url": "https://x.com/JavierBlas/status/2074840269577507228", "text": "President Trump says US probably will strike Iran for a second time tonight.", "time": "12:57", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 50247, "likes": 338, "replies": 17, "retweets": 49, "quotes": 8, "bookmarks": 14, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Negative", "topics": ["Iran", "Geopolitics"]}}, {"id": "2074841618574893206", "url": "https://x.com/DarioCpx/status/2074841618574893206", "text": "JustDarioDaily - Podcast\n\n⚠️ Oil Shorts Are Now Fighting Not To Be Brutally Squeezed Out 🎙️ \n\n#OOTT\n\nhttps://t.co/mdxVuP2Mi5", "time": "13:02", "author": "DarioCpx", "author_name": "JustDario", "followers": 113107, "views": 145532, "likes": 150, "replies": 20, "retweets": 13, "quotes": 1, "bookmarks": 19, "labels": {"relevant": true, "price_sentiment": "Bullish", "emotional_sentiment": "Positive", "topics": ["Prices/technicals"]}}, {"id": "2074855873826918779", "url": "https://x.com/JavierBlas/status/2074855873826918779", "text": "We are back to the days of Donald \"the-madman\" Trump threatening to take over Kharg Island (never happened then;