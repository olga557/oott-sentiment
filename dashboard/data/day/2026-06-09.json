ts", "b": "oilprice", "w": 1}, {"a": "lng", "b": "oilgas", "w": 1}, {"a": "energy", "b": "wti", "w": 1}, {"a": "oil", "b": "us", "w": 1}, {"a": "crude", "b": "energy", "w": 1}, {"a": "commodities", "b": "crudeoil", "w": 1}]}, "top_tweets": [{"id": "2064244527162900992", "url": "https://x.com/staunovo/status/2064244527162900927", "text": "US gasoline stocks near critical low as exports face summer strain: CERA\n#oott https://t.co/hlaPsbk4vi", "time": "07:13", "author": "staunovo", "author_name": "Giovanni Staunovo🛢", "followers": 119640, "views": 29606, "likes": 76, "replies": 1, "retweets": 15, "quotes": 6, "bookmarks": 11, "labels": null}, {"id": "2064252303352135936", "url": "https://x.com/staunovo/status/2064252303352136023", "text": "#China: crude imports were at 7.82mbpd in May 26, vs 9.40 in April 26, 11.02mbpd in May 25, 11.11mbpd in May 24, 12.16mbpd in May 23 - customs office data #oott https://t.co/AvvVxtzNSZ", "time": "07:44", "author": "staunovo", "author_name": "Giovanni Staunovo🛢", "followers": 119640, "views": 36128, "likes": 112, "replies": 12, "retweets": 30, "quotes": 7, "bookmarks": 23, "labels": null}, {"id": "2064261911546380353", "url": "https://x.com/JavierBlas/status/2064261911546380353", "text": "US President Donald Trump overnight said that he hoped to have news on Iran in the next couple of days.\n\n“We have ongoing negotiations with Iran, that hasn’t stopped,” he said. “I think it’s going well.”\n\n(And yes, yes, and yes, he had said that multiple times in the past).", "time": "08:22", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 38217, "likes": 164, "replies": 33, "retweets": 15, "quotes": 6, "bookmarks": 8, "labels": null}, {"id": "2064263955439116613", "url": "https://x.com/JavierBlas/status/2064263955439116613", "text": "Significant amount of Middle Eastern oil is leaving the Persian Gulf by tanker via the Strait of Hormuz (in addition of the bypass pipelines).\n\nThe telltale is the decline over the last few weeks of onshore crude inventories. Plus the surge in STS activity just outside Hormuz.", "time": "08:30", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 267224, "likes": 1025, "replies": 37, "retweets": 250, "quotes": 17, "bookmarks": 184, "labels": null}, {"id": "2064289228230447251", "url": "https://x.com/JavierBlas/status/2064289228230447251", "text": "Kuwait is offering to sell its crude to refiners in Asia for the first time since the Iran war started.\n\nAnother key sign that more Middle Eastern crude is flowing “dark” via the Strait of Hormuz by tanker (on top of what’s moved via bypass pipelines) \n\nhttps://t.co/A3NNcXKNod", "time": "10:11", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 123418, "likes": 796, "replies": 40, "retweets": 237, "quotes": 30, "bookmarks": 112, "labels": null}, {"id": "2064321542658396206", "url": "https://x.com/JavierBlas/status/2064321542658396206", "text": "BP confirms the reorganisation of its business back into the traditional Big Oil model of upstream and downstream.\n\nGordon Birrell will run upstream and Richard Harding downstream (on an interim basis). The leadership of renewables is downgraded massively and folded into BP’s technology function. \n\n", "time": "12:19", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 35680, "likes": 165, "replies": 17, "retweets": 35, "quotes": 6, "bookmarks": 16, "labels": null}, {"id": "2064341260677394944", "url": "https://x.com/JuneGoh_Sparta/status/2064341260677394911", "text": "WTI Afra arb to NWE is shut. I repeat, WTI Afra arb to NWE is shut.\n#oott https://t.co/PCdJ8YxQkR", "time": "13:38", "author": "JuneGoh_Sparta", "author_name": "June Goh", "followers": 17573, "views": 22659, "likes": 83, "replies": 9, "retweets": 9, "quotes": 2, "bookmarks": 18, "labels": null}, {"id": "2064344689244005120", "url": "https://x.com/Amena__Bakr/status/2064344689244004546", "text": "Covert tanker operations have successfully cracked Kuwait’s 2-month export freeze, triggering a significant inventory draw at Mina Al Ahmadi as operators turn to dark transits to bypass regional maritime blockades. More on @Kpler #OOTT #Kuwait", "time": "13:51", "author": "Amena__Bakr", "author_name": "Amena Bakr", "followers": 173868, "views": 134594, "likes": 221, "replies": 18, "retweets": 52, "quotes": 11, "bookmarks": 30, "labels": null}, {"id": "2064368321911198054", "url": "https://x.com/JavierBlas/status/2064368321911198054", "text": "U.S. Energy Secretary Chris Wright said oil traffic throughout the Strait of Hormuz has risen “very meaningfully.”", "time": "15:25", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 70078, "likes": 411, "replies": 70, "retweets": 63, "quotes": 8, "bookmarks": 20, "labels": null}, {"id": "2064405546426372096", "url": "https://x.com/staunovo/status/2064405546426372343", "text": "EIA estimates a total of around 15.43mbpd of supplies were offline in May versus 15.55mbpd in April #oott https://t.co/l5XVhgQgRZ", "time": "17:53", "author": "staunovo", "author_name": "Giovanni Staunovo🛢", "followers": 119640, "views": 10724, "likes": 57, "replies": 2, "retweets": 17, "quotes": 4, "bookmarks": 17, "labels": null}, {"id": "2064407940082098228", "url": "https://x.com/JavierBlas/status/2064407940082098228", "text": "Energy factoid of the day:\n\nThe entire annual global LNG market equals to about six weeks of coal demand in China and India.", "time": "18:03", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 107559, "likes": 1130, "replies": 26, "retweets": 260, "quotes": 28, "bookmarks": 132, "labels": null}, {"id": "2064409073148121088", "url": "https://x.com/staunovo/status/2064409073148121361", "text": "Oil inventories headed toward multi-decade lows, US EIA warns #oott https://t.co/2FcMCYRH8c", "time": "18:07", "author": "staunovo", "author_name": "Giovanni Staunovo🛢", "followers": 119640, "views": 64115, "likes": 98, "replies": 5, "retweets": 22, "quotes": 5, "bookmarks": 16, "labels": null}, {"id": "2064420467805438214", "url": "https://x.com/JavierBlas/status/2064420467805438214", "text": "The more Middle East oil producing nations manage to sneak out some of their barrels before the Strait of Hormuz is “formally” re-opened via a U.S.-Iran deal, the easier is for said countries to re-star their oilfields. Emptying onshore storage is first step for any re-start.", "time": "18:52", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 81258, "likes": 349, "replies": 22, "retweets": 67, "quotes": 5, "bookmarks": 37, "labels": null}, {"id": "2064447392850543104", "url": "https://x.com/JuliOnTwtr/status/2064447392850542698", "text": "API Inventory Moves 6/9\n\nCrude -9.119 million (exp. -3.4 million)\nGasoline -1.191 million\nCushing -1.125 million\n\nSPR actual -7.9 million\n\n#oott #crudeoil #API #gasoline", "time": "20:39", "author": "JuliOnTwtr", "author_name": "Julianne Geiger", "followers": 8462, "views": 57035, "likes": 239, "replies": 20, "retweets": 33, "quotes": 12, "bookmarks": 15, "labels": null}, {"id": "2064448657445794048", "url": "https://x.com/JuliOnTwtr/status/2064448657445793969", "text": "API Inventory Moves 6/9 (full version)\n Crude -9.119 million (exp. -3.4 million) \nGasoline -1.191 million \nDistillates +1.3 million\nCushing -1.125 million  \nSPR actual -7.9 million \n #oott #crudeoil #API #gasoline", "time": "20:44", "author": "JuliOnTwtr", "author_name": "Julianne Geiger", "followers": 8462, "views": 83890, "likes": 334, "replies": 26, "retweets": 64, "quotes": 18, "bookmarks": 18, "labels": null}, {"id": "2064458725381771400", "url": "https://x.com/JavierBlas/status/2064458725381771400", "text": "US stricking Iran in response to the downing of a helicopter", "time": "21:24", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 68892, "likes": 109, "replies": 12, "retweets": 14, "quotes": 1, "bookmarks": 4, "labels": null}, {"id": "2064478677916684714", "url": "https://x.com/JavierBlas/status/2064478677916684714", "text": "Iran is telegraphing that it will retaliate against the latest US strikes", "time": "22:44", "author": "JavierBlas", "author_name": "Javier Blas", "followers": 393796, "views": 32788, "likes": 213, "replies": 18, "retweets": 33, "quotes": 3, "bookmarks": 8, "labels": null}, {"id": "2064482704175801088", "url": "https://x.com/OilandEnergy/status/2064482704175800642", "text": "Oil traders may be underestimating the severity of the supply crisis. The IEA says nearly 13 million bpd of supply has been lost since February, while global inventories are being depleted at a record pace. #OilMarkets #EnergySecurity #OOTT #CrudeOil \n\nhttps://t.co/z8b7PEp7Vl", "time": "23:00", "author": "OilandEnergy", "author_name": "OilPrice.com", "followers": 95942, "views": 9640, "likes": 192, "replies": 8, "retweets": 44, "quotes": 3, "bookmarks": 14, "labels": null}], "top_authors_by_tweets": [{"username": "staunovo", "name": "Giovanni Staunovo🛢", "followers": 119640, "tweets": 45, "views": 321245, "likes": 866}, {"username": "finsquawk_", "name": "FinSquawk", "followers": 2158, "tweets": 32, "views": 9788, "likes": 10}, {"username": "MktPulseIndia", "name": "MarketPulse India", "followers": 842, "tweets": 18, "views": 5753, "likes": 11}, {"username": "ZmansEnrgyBrain", "name": "Z4 Energy Research", "followers": 11776, "tweets": 16, "views": 39502, "likes": 182}, {"username": "JavierBlas", "name": "Javier Blas", "followers": 393796, "tweets": 10, "views": 860778, "likes": 4458}], "top_authors_by_views": [{"username": "JavierBlas", "name": "Javier Blas", "followers": 393796, "tweets": 10, "views": 860778, "likes": 4458}, {"username": "staunovo", "name": "Giovanni Staunovo🛢", "followers": 119640, "tweets": 45, "views": 321245, "likes": 866}, {"username": "Amena__Bakr", "name": "Amena Bakr", "foll